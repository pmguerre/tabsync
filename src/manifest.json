{
  "manifest_version": 3,
  "name": "TabSync",
  "description": "Sincroniza e guarda sessões de separadores por janela.",
  "version": "1.3",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "storage",
    "tabGroups"
  ]
}
